# 이 파일을 .env 로 복사한 뒤 값을 채우세요.  cp .env.example .env
# (.env 는 .gitignore 에 의해 커밋되지 않습니다)

# === Discord 알림 (둘 중 하나만 채우면 됩니다) ===
# 방법 A) 웹훅 — 가장 간단, 권장
DISCORD_WEBHOOK_URL=

# 방법 B) 봇 토큰 + 채널 ID
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# === 모니터링 옵션 (선택) ===
CASPER_REGION_CODE=4825
CASPER_REGION_NAME="경남 김해시"
CASPER_INTERVAL_SEC=3600
# CASPER_NOTIFY_EACH_CHECK=1
